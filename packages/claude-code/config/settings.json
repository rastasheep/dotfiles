{
  "permissions": {
    "allow": [
      "Bash(git add:*)"
    ],
    "deny": [],
    "ask": []
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>"
  },
  "statusLine": {
    "type": "command",
    "command": "jq -r '(env.PWD // \"–\") + \"\\n\" + (.session_id // \"–\") + \" \" + (.model.display_name // \"–\") + \" \" + (.effort.level // \"–\") + \" $\" + (.cost.total_cost_usd // 0 | tostring) + \" \" + (.context_window.used_percentage // 0 | tostring) + \"%\"'",
    "refreshInterval": 10
  }
}
